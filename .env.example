# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
# Your Render.com public URL (no trailing slash)
SERVER_URL=https://your-app.onrender.com

# ─── App info ────────────────────────────────────────────────────────────────
BUNDLE_ID=com.rushdriver.app
APP_NAME=Rush Driver
APP_VERSION=1.0.0

# Set this after each fastlane build (the GitHub Release download URL)
LATEST_IPA_URL=

# ─── Apple App Store Connect API ─────────────────────────────────────────────
# Generate at: https://appstoreconnect.apple.com/access/api
# Needs "Developer" role minimum for device registration
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Paste the full .p8 key contents (newlines as \n)
ASC_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nMHQC...\n-----END EC PRIVATE KEY-----"

# ─── Notifications (pick one or both, all are optional) ──────────────────────
# ntfy.sh — free push notifications on iPhone, no account needed
# 1. Install "ntfy" app on iPhone
# 2. Pick any unique topic name (keep it private, treat it like a password)
# 3. Subscribe to it in the app
NTFY_TOPIC=rushdriver-beta-yourname

# Discord webhook — paste URL from Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
